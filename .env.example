# 정몽주 AR 서버 환경변수 — 복사해서 .env 로 사용 (.env 는 커밋 금지)

# Anthropic API 키 (비우면 데모 모드로 동작: 데모 응답·미션 자동 통과)
ANTHROPIC_API_KEY=

# 사용 모델
CLAUDE_MODEL=claude-sonnet-4-20250514

# 현장 좌표·반경 [CONFIRM] — 실제 측량값으로 교체
SITE_NAME=정몽주 묘
SITE_LAT=37.31866
SITE_LNG=127.21931
SITE_RADIUS_M=150
SITE_LEAVE_BUFFER_M=60

# 회전 QR 토큰 [CONFIRM]
QR_SECRET=poeun-dev-secret-change-me
QR_TTL_SEC=300
QR_ROTATE_SEC=180
# 키오스크 QR에 넣을 공개 주소(미지정 시 요청 호스트 사용). 예: https://poeun.example.com
PUBLIC_ORIGIN=

# 서버 포트
PORT=3001
